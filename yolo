#!/usr/bin/env php
<?php

use Dotenv\Dotenv;
use Codinglabs\Yolo\Yolo;

file_exists(__DIR__ . '/../../autoload.php')
    ? require __DIR__ . '/../../autoload.php'
    : require __DIR__ . '/vendor/autoload.php';

// Resolve the consuming app's root.
// - vendor install: __DIR__ is vendor/codinglabsau/yolo, app root is __DIR__/../../../
// - path repo / symlink install: fall back to getcwd() so the user's working directory drives it
// - explicit override always wins via YOLO_BASE_PATH
define('BASE_PATH', $_ENV['YOLO_BASE_PATH']
    ?? (file_exists(__DIR__ . '/../../autoload.php')
        ? __DIR__ . '/../../../'
        : getcwd()));

if (file_exists(BASE_PATH . '/.env')) {
    Dotenv::createImmutable(BASE_PATH)->load();
}

$yolo = new Yolo();
$yolo->run();
