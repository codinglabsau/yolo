#!/usr/bin/env bash
#
# yolo-credentials-1password — emit short-lived AWS credentials for `credential_process`.
#
# Reads long-lived keys (and, if present, an MFA device + TOTP) from a 1Password
# item, mints a GetSessionToken session, and caches it until shortly before
# expiry so the AWS CLI / YOLO don't re-prompt — and don't reuse a TOTP — on
# every call. Long-lived keys never touch disk; only the short-lived session does.
#
# Wire up in ~/.aws/config:
#   [profile my-app-production]
#   credential_process = /path/to/yolo-credentials-1password "AWS my-app production"
#   region = ap-southeast-2
#
# MFA is used automatically when the IAM user has an MFA device registered in
# AWS (discovered at mint time via iam:ListMFADevices — the device ARN is not
# stored). The TOTP, which can't be derived, comes from the item. Forwarding MFA
# to accounts that don't enforce it is harmless (STS still issues a session) and
# future-proof if enforcement is later turned on. No device — or no permission
# to list one — means a plain session, with a warning.
#
# Deps: 1Password `op`, AWS CLI, jq. The 1Password item needs fields:
#   aws_access_key_id, aws_secret_access_key
# For an IAM user with an MFA device, also add a one-time-password (TOTP) field.
# Grant iam:ListMFADevices on self so the device can be discovered.
#
set -euo pipefail

item="${1:?usage: yolo-credentials-1password <1Password item name> [vault]}"
vault="${2:-Employee}"
duration=14400   # 4h session; the on-disk exposure window on a lost laptop

dir="$HOME/.aws/yolo-cache"
mkdir -p "$dir"
chmod 700 "$dir"
cache_key="${vault// /_}_${item// /_}"
cache="$dir/$cache_key.json"
until_file="$dir/$cache_key.until"

# Reuse the cached session while it's still valid.
if [ -f "$cache" ] && [ -f "$until_file" ] && [ "$(date +%s)" -lt "$(cat "$until_file")" ]; then
  cat "$cache"
  exit 0
fi

# One fetch pulls everything we might need: both keys, the MFA device serial,
# and (for an OTP field) a live TOTP code — so even the MFA path is a single op
# round-trip. The whole item enters this process; nothing is persisted.
item_json=$(op item get "$item" --vault "$vault" --format json)
field() { jq -r --arg l "$1" 'first(.fields[] | select(.label == $l) | .value) // empty' <<<"$item_json"; }

key=$(field aws_access_key_id)
secret=$(field aws_secret_access_key)
[ -n "$key" ] && [ -n "$secret" ] || {
  echo "yolo-credentials-1password: '$item' is missing aws_access_key_id / aws_secret_access_key" >&2
  exit 1
}

# Discover the IAM user's MFA device from AWS — the source of truth — rather
# than storing its ARN. Needs iam:ListMFADevices on self, which a force-MFA
# policy carves out so it still works before an MFA session exists. One extra
# ~1s call, only on a cold mint. (Takes the first device; a user with several
# would need the one matching the stored TOTP.)
mfa_args=()
serial=$(AWS_ACCESS_KEY_ID="$key" AWS_SECRET_ACCESS_KEY="$secret" \
  aws iam list-mfa-devices --query 'MFADevices[0].SerialNumber' --output text 2>/dev/null || true)
[ "$serial" = "None" ] && serial=""

if [ -n "$serial" ]; then
  # TOTP isn't derivable — take it from the same fetch, or a dedicated --otp call.
  code=$(jq -r 'first(.fields[] | select(.type == "OTP") | .totp) // empty' <<<"$item_json")
  [ -n "$code" ] || code=$(op item get "$item" --vault "$vault" --otp 2>/dev/null || true)
  if [ -n "$code" ]; then
    mfa_args=(--serial-number "$serial" --token-code "$code")
  else
    echo "yolo-credentials-1password: '$item' user has an MFA device but no TOTP in 1Password — authenticating WITHOUT MFA." >&2
  fi
else
  echo "yolo-credentials-1password: no MFA device for '$item' (or iam:ListMFADevices not granted) — authenticating WITHOUT MFA." >&2
fi

creds=$(AWS_ACCESS_KEY_ID="$key" AWS_SECRET_ACCESS_KEY="$secret" \
  aws sts get-session-token \
    ${mfa_args[@]+"${mfa_args[@]}"} \
    --duration-seconds "$duration" \
    --query 'Credentials.{Version:`1`,AccessKeyId:AccessKeyId,SecretAccessKey:SecretAccessKey,SessionToken:SessionToken,Expiration:Expiration}' \
    --output json)

umask 077
printf '%s\n' "$creds" > "$cache"
echo "$(( $(date +%s) + duration - 300 ))" > "$until_file"
printf '%s\n' "$creds"
